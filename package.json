{
  "name": "prisma-sql-logger",
  "version": "0.1.0",
  "description": "Log Prisma queries with parameters inlined as runnable SQL",
  "keywords": [
    "prisma",
    "sql",
    "logger",
    "logging",
    "postgresql",
    "postgres",
    "debug",
    "query"
  ],
  "author": "sillysillyman",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sillysillyman/prisma-sql-logger.git"
  },
  "homepage": "https://github.com/sillysillyman/prisma-sql-logger#readme",
  "bugs": {
    "url": "https://github.com/sillysillyman/prisma-sql-logger/issues"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run --exclude 'tests/**'",
    "test:watch": "vitest --exclude 'tests/**'",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:setup": "bash scripts/setup-test-db.sh",
    "generate:schema": "tsx scripts/generate-schema.ts",
    "lint": "eslint src",
    "format": "prettier --write .",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run lint && npm run typecheck && npm run test && npm run build"
  },
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@prisma/client": "^6.19.3",
    "@types/node": "^25.5.2",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "dotenv": "^17.4.2",
    "eslint": "^10.2.0",
    "prettier": "^3.8.1",
    "prisma": "^6.19.3",
    "tsup": "^8.5.1",
    "typescript": "~5.7.0",
    "vitest": "^4.1.3"
  }
}
